      "item": [
        {
          "name": "productInfo",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"auth\": {\n    \"key\": \"{{axisroomsApiKey}}\"\n  },\n  \"propertyId\": \"{{propertyId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}{{apiPrefix}}/axisrooms/productInfo",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{apiPrefix}}",
                "axisrooms",
                "productInfo"
              ]
            },
            "description": "POST /api/v1/axisrooms/productInfo\n\nBody shape from ProductInfoRequestDto: { auth, propertyId }."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var json = {};",
                  "try { json = pm.response.json(); } catch (e) {}",
                  "",
                  "pm.test('Response has status field', function () {",
                  "  pm.expect(json).to.have.property('status');",
                  "});",
                  "",
                  "if (Array.isArray(json.data) && json.data.length > 0 && json.data[0].id) {",
                  "  pm.collectionVariables.set('roomId', String(json.data[0].id));",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
