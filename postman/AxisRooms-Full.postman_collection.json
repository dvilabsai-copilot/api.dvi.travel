      "name": "AxisRooms Admin APIs",
      "description": "Routes guarded by AdminKeyGuard. ADMIN key must be sent in x-admin-key header.",
      "item": [
        {
          "name": "GET hotels",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-admin-key",
                "value": "{{adminKey}}",
                "type": "text"
              }
