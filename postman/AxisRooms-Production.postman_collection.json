          "raw": "{\n  \"auth\": {\n    \"key\": \"{{axisroomsApiKey}}\"\n  },\n  \"data\": [\n    {\n      \"propertyId\": \"{{propertyId}}\",\n      \"roomDetails\": [\n        {\n          \"roomId\": \"{{roomId}}\",\n          \"ratePlanDetails\": [\n            {\n              \"ratePlanId\": \"{{rateplanId}}\",\n              \"restrictions\": {\n                \"periods\": [\n                  {\n                    \"startDate\": \"{{startDate}}\",\n                    \"endDate\": \"{{endDate}}\"\n                  }\n                ],\n                \"type\": \"COA\",\n                \"value\": \"Close\"\n              }\n            }\n          ]\n        }\n      ]\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}{{apiPrefix}}/axisrooms/restrictionUpdate",
          "host": ["{{baseUrl}}"],
          "path": ["{{apiPrefix}}", "axisrooms", "restrictionUpdate"]
