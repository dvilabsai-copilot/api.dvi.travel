      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"auth\": {\n    \"key\": \"{{axisroomsApiKey}}\"\n  },\n  \"data\": [\n    {\n      \"propertyId\": \"{{propertyId}}\",\n      \"roomDetails\": [\n        {\n          \"roomId\": \"{{roomId}}\",\n          \"ratePlanDetails\": [\n            {\n              \"ratePlanId\": \"{{rateplanId}}\",\n              \"restrictions\": {\n                \"periods\": [\n                  {\n                    \"startDate\": \"{{startDate}}\",\n                    \"endDate\": \"{{endDate}}\"\n                  }\n                ],\n                \"type\": \"MLos\",\n                \"value\": \"3\"\n              }\n            }\n          ]\n        }\n      ]\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}{{apiPrefix}}/axisrooms/restrictionUpdate",
          "host": ["{{baseUrl}}"],
          "path": ["{{apiPrefix}}", "axisrooms", "restrictionUpdate"]
        }
      }
    },
