{
  "info": {
    "name": "STAAH CM-OTA APIs",
    "description": "STAAH Channel Manager OTA integration endpoints. All requests require `apikey` in the body.\n\nVariables:\n- `baseUrl`       → server base (e.g. https://dvi.travel or http://localhost:4006)\n- `apiPrefix`     → /api/v1\n- `staahApiKey`   → value of STAAH_API_KEY on the server\n- `propertyId`    → STAAH property ID\n- `roomId`        → room ID\n- `ratePlanId`    → rate plan ID",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",     "value": "https://dvi.travel",                       "type": "string" },
    { "key": "apiPrefix",   "value": "/api/v1",                                  "type": "string" },
    { "key": "staahApiKey", "value": "staah_C3g8K3b1wray989DVih37od3314r6444",  "type": "string" },
    { "key": "propertyId",  "value": "STAAH_TEST_HOTEL_1",                       "type": "string" },
    { "key": "roomId",      "value": "DELUXE_ROOM",                              "type": "string" },
    { "key": "ratePlanId",  "value": "CP_PLAN",                                  "type": "string" },
    { "key": "startDate",   "value": "2026-10-01",                               "type": "string" },
    { "key": "endDate",     "value": "2026-10-31",                               "type": "string" }
  ],
  "item": [
    {
      "name": "Authentication",
      "description": "Tests for guard behaviour — invalid / missing API key.",
      "item": [
        {
          "name": "Invalid API Key → 401",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}{{apiPrefix}}/staah/productInfo", "host": ["{{baseUrl}}{{apiPrefix}}"], "path": ["staah", "productInfo"] },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"apikey\": \"wrong-key\",\n  \"propertyid\": \"{{propertyId}}\",\n  \"action\": \"property_info\",\n  \"version\": \"2\"\n}"
            }
          }
        },
        {
          "name": "Missing Auth Credentials → 401",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
